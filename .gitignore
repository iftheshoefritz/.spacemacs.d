# Auto-generated Customize output (org-agenda-files, package-selected-packages,
# and any future Customize churn). Redirected here via custom-file in init.el.
custom.el

# Machine-specific environment dump generated by Spacemacs
.spacemacs.env

# Machine-local org-gcal values (personal email + absolute calendar paths).
# Copy org-gcal-local.el.example to org-gcal-local.el and fill in.
org-gcal-local.el

# Machine-local org-capture templates (client/colleague names + note paths).
# Copy org-capture-templates-local.el.example to org-capture-templates-local.el.
org-capture-templates-local.el

# Machine-local note paths + work context (org dirs, client name/file).
# Copy paths-local.el.example to paths-local.el and fill in.
paths-local.el

# Secrets / OAuth tokens (should never live here, but guard anyway)
oauth2-auto.plist
oauth2-auto.plist~
*.plstore

# Byte-compiled / native-compiled artifacts
*.elc
*.eln
eln-cache/

# Claude Code MCP runtime log (contains absolute machine paths)
.claude-code-mcp.log

# Editor / OS cruft
.DS_Store
*~
\#*\#
.\#*
